# Check required env variables
if [[ $ASK_API_URL == "" ]];then
    echo "ASK_API_URL environment variable is missing."
    exit 1
fi

if [[ $ASK_MODEL == "" ]];then
    echo "ASK_MODEL environment variable is missing."
    exit 1
fi

if [[ $ASK_API_KEY == "" ]];then
    echo "ASK_API_KEY environment variable is missing."
    exit 1
fi

# Initialize input holders
ARGS=""
STDIN=""

# Read CLI arguments
if [[ $# != 0 ]]; then
  ARGS="$*"
fi

# Read piped input
if [[ ! -t 0 ]]; then
  STDIN=$(cat)
fi

# Build prompt from args + stdin
if [[ -z "$ARGS" && -z "$STDIN" ]]; then
    echo "Error: No input provided. Prompt is required either as an argument or through piped input."
    exit 1
elif [[ -n "$ARGS" && -n "$STDIN" ]]; then
    PROMPT="${ARGS}"$'\n'"${STDIN}"
else
    PROMPT="${ARGS}${STDIN}"
fi

# Debug: print prompt
# echo "$PROMPT"

# Build JSON request body using jq
REQUEST=$(jq -n \
--arg model "${ASK_MODEL}" \
--arg prompt "${PROMPT}" \
'{
    model: $model,
    messages: [
        {
        role: "system",
        content: "You are a CLI tool. Output plain text only. No yapping. Keep the output concise."
        },
        {
        role: "user",
        content: $prompt  
        }
    ]
}')

# Send request with curl + append HTTP status 
RESPONSE=$(curl "${ASK_API_URL}" -s \
    -w "\n%{http_code}" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer ${ASK_API_KEY}" \
    -d "${REQUEST}")

# Check curl execution status
CURL_EXIT=$?
if [[ $CURL_EXIT -ne 0 ]]; then
    echo "Error: Request failed."
    exit 1
fi

# Extract HTTP status code and body
STATUS=$(echo "$RESPONSE" | sed -n '$p')
BODY=$(echo "$RESPONSE" | sed '$d')

# Validate JSON response
echo "$BODY" | jq . >/dev/null 2>&1
if [[ $? -ne 0 ]]; then
    echo "Error: Invalid response (not JSON)."
    exit 1
fi

# Check HTTP status
if [[ "$STATUS" != "200" ]]; then
    # Read possible API error message
    ERROR=$(echo "$BODY" | jq -r '.error.message // .error // "No message provided"')
    echo "HTTP Error: $STATUS - $ERROR"
    exit 1
fi

# Output Extraction
OUTPUT=$(echo "$BODY" | jq -r '.choices[0].message.content')
echo "$OUTPUT"

