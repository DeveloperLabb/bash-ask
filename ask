#!/bin/bash
if [[ $ASK_API_URL == "" ]];then
    echo "API_URL is missing."
    exit 1
fi

if [[ $ASK_MODEL == "" ]];then
    echo "MODEL is missing."
    exit 1
fi

if [[ $ASK_API_KEY == "" ]];then
    echo "API_KEY is missing."
    exit 1
fi

args=""
stdin=""

if [[ $# != 0 ]]; then
  args="$*"
fi

if [[ ! -t 0 ]]; then
  stdin=$(cat)
fi

if [[ -n "$args" && -n "$stdin" ]]; then
    prompt="${args}, ${stdin}"
elif [[ -n "$args" ]]; then
    prompt="$args"
else
    prompt="$stdin"
fi

if [[ $prompt == "" ]]; then
    echo "Prompt is empty."
    exit 1
fi

echo "Prompt: $prompt"




